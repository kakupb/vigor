{
  "expo": {
    "name": "Vigor",
    "slug": "vigor",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "vigor",
    "userInterfaceStyle": "automatic",
    "updates": {
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0,
      "url": "https://u.expo.dev/28a83525-f119-44d7-a682-9dc17fb6ccea"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "ios": {
      "buildNumber": "4",
      "supportsTablet": true,
      "bundleIdentifier": "com.yakubadar.vigor",
      "entitlements": {
        "com.apple.developer.healthkit": true,
        "com.apple.developer.healthkit.access": []
      },
      "infoPlist": {
        "NSHealthClinicalHealthRecordsShareUsageDescription": "Vigor liest keine klinischen Gesundheitsdaten.",
        "NSPhotoLibraryUsageDescription": "Vigor verwendet deine Fotobibliothek, um Bilder zu Notizen hinzuzufügen.",
        "NSPhotoLibraryAddUsageDescription": "Vigor speichert Bilder aus der App in deiner Fotobibliothek.",
        "NSCameraUsageDescription": "Vigor verwendet die Kamera, um Fotos direkt in Notizen einzufügen.",
        "NSMicrophoneUsageDescription": "Das Mikrofon wird für Videoaufnahmen benötigt, die in Notizen eingebettet werden.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.yakubadar.vigor",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "./plugins/withFollyCoroutineFix",
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "Vigor verwendet deine Fotobibliothek, um Bilder zu Notizen hinzuzufügen.",
          "cameraPermission": "Vigor verwendet die Kamera, um Fotos direkt in Notizen einzufügen.",
          "microphonePermission": false
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#3b8995",
          "sounds": []
        }
      ],
      [
        "react-native-health",
        {
          "NSHealthShareUsageDescription": "Vigor liest Workout- und Aktivitätsdaten aus Apple Health, damit du Trainings in deinen Planner importieren und Gesundheitsmetriken in der Analyse sehen kannst.",
          "NSHealthUpdateUsageDescription": "Vigor schreibt keine Daten in Apple Health."
        }
      ],
      "expo-video",
      "expo-secure-store",
      "expo-audio",
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "28a83525-f119-44d7-a682-9dc17fb6ccea"
      }
    },
    "owner": "kakupb"
  }
}
